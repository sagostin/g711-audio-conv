# ======================
# Audio Converter Config
# ======================

# Domain / address for Caddy
# Use "localhost" for local dev (self-signed cert)
# Use your real domain for production (auto Let's Encrypt)
SITE_ADDRESS=localhost

# Email for Let's Encrypt certificate registration
# Set to "internal" for self-signed certs (local dev)
TLS_EMAIL=internal

# Server port (internal, Caddy proxies to this)
PORT=8080

# Header for client IP (set by Caddy automatically)
PROXY_HEADER=X-Forwarded-For

# Maximum upload size in MB
MAX_UPLOAD_MB=200

# Comma-separated IPs for easter egg mode (optional)
EASTER_EGG_IPS=
